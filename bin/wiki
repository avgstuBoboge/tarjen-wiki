#!/usr/bin/env bash
# bin/wiki — Wiki CLI 入口
#
# 直接 exec venv python + tools.cli_main, 无后端进程.
# 所有数据/操作都是本地的 (csv / git / md), 不需要 HTTP server.
#
# 安装:
#   ./bootstrap.sh   # 装到 ~/.local/bin/wiki

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PY="$REPO_ROOT/.venv/bin/python"
if [[ ! -x "$PY" ]]; then
    echo "✗ 找不到 venv python ($PY), 跑 ./bootstrap.sh 装 venv" >&2
    exit 1
fi

cd "$REPO_ROOT"
exec "$PY" -m tools.cli_main "$@"